  "html": "\n<style>\n    .slip { font-family: Arial, sans-serif; max-width: 400px; margin: 0 auto; border: 2px solid #2563EB; border-radius: 10px; padding: 20px; }\n    .slip-header { text-align: center; border-bottom: 1px solid #eee; padding-bottom: 10px; margin-bottom: 15px; }\n    .slip-header h2 { color: #2563EB; margin: 0; }\n    .slip-body div { margin: 8px 0; }\n    .slip-body strong { display: inline-block; min-width: 120px; }\n    .slip-footer { text-align: center; margin-top: 20px; padding-top: 10px; border-top: 1px solid #eee; font-size: 12px; color: #888; }\n</style>\n\n<div class=\"slip\">\n    <div class=\"slip-header\">\n        <h2>BDC Hospital</h2>\n        <p>Appointment Slip</p>\n    </div>\n    <div class=\"slip-body\">\n        <div><strong>Patient:</strong> {{ doc.patient_name }}</div>\n        <div><strong>Doctor:</strong> {{ doc.practitioner_name }}</div>\n        <div><strong>Department:</strong> {{ doc.department or \"\" }}</div>\n        <div><strong>Date:</strong> {{ doc.appointment_date }}</div>\n        <div><strong>Time:</strong> {{ doc.appointment_time }}</div>\n        <div><strong>Type:</strong> {{ doc.appointment_type or \"\" }}</div>\n        <div><strong>Room:</strong> {{ doc.service_unit or \"\" }}</div>\n        <div><strong>Appointment #:</strong> {{ doc.name }}</div>\n    </div>\n    <div class=\"slip-footer\">\n        Please arrive 15 minutes before your appointment time.\n    </div>\n</div>\n",
