  "format_data": null,
  "html": "\n<style>\n    .prescription { font-family: Arial, sans-serif; direction: ltr; }\n    .header { text-align: center; border-bottom: 2px solid #2563EB; padding-bottom: 10px; margin-bottom: 20px; }\n    .header h1 { color: #2563EB; margin: 0; font-size: 24px; }\n    .header p { margin: 5px 0; color: #666; }\n    .patient-info { display: flex; justify-content: space-between; margin-bottom: 20px; padding: 10px; background: #f8f9fa; border-radius: 5px; }\n    .patient-info div { flex: 1; }\n    .rx-symbol { font-size: 28px; color: #2563EB; font-weight: bold; margin: 10px 0; }\n    .drugs-table { width: 100%; border-collapse: collapse; margin: 15px 0; }\n    .drugs-table th { background: #2563EB; color: white; padding: 8px 12px; text-align: left; }\n    .drugs-table td { padding: 8px 12px; border-bottom: 1px solid #eee; }\n    .drugs-table tr:nth-child(even) { background: #f8f9fa; }\n    .diagnosis { margin: 15px 0; padding: 10px; border-left: 3px solid #2563EB; background: #f0f7ff; }\n    .footer { margin-top: 40px; display: flex; justify-content: space-between; }\n    .signature { text-align: center; border-top: 1px solid #333; padding-top: 5px; min-width: 200px; }\n</style>\n\n<div class=\"prescription\">\n    <div class=\"header\">\n        <h1>BDC Hospital</h1>\n        <p>{{ doc.company_address or \"\" }}</p>\n        <p>Tel: {{ doc.company_phone or \"\" }}</p>\n    </div>\n\n    <div class=\"patient-info\">\n        <div>\n            <strong>Patient:</strong> {{ doc.patient_name }}<br>\n            <strong>Age/Gender:</strong> {{ doc.patient_age or \"\" }} / {{ doc.patient_sex or \"\" }}\n        </div>\n        <div style=\"text-align: right;\">\n            <strong>Date:</strong> {{ doc.encounter_date }}<br>\n            <strong>Doctor:</strong> {{ doc.practitioner_name }}<br>\n            <strong>Department:</strong> {{ doc.medical_department or \"\" }}\n        </div>\n    </div>\n\n    {% if doc.diagnosis %}\n    <div class=\"diagnosis\">\n        <strong>Diagnosis:</strong><br>\n        {% for d in doc.diagnosis %}\n            {{ d.diagnosis }} {{ \"(\" + d.medical_code + \")\" if d.medical_code else \"\" }}<br>\n        {% endfor %}\n    </div>\n    {% endif %}\n\n    {% if doc.drug_prescription %}\n    <div class=\"rx-symbol\">℞</div>\n    <table class=\"drugs-table\">\n        <thead>\n            <tr>\n                <th>#</th>\n                <th>Drug</th>\n                <th>Dosage</th>\n                <th>Period</th>\n                <th>Comment</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for drug in doc.drug_prescription %}\n            <tr>\n                <td>{{ loop.index }}</td>\n                <td><strong>{{ drug.drug_name or drug.drug_code }}</strong></td>\n                <td>{{ drug.dosage or \"\" }} {{ drug.dosage_form or \"\" }}</td>\n                <td>{{ drug.period or \"\" }}</td>\n                <td>{{ drug.comment or \"\" }}</td>\n            </tr>\n            {% endfor %}\n        </tbody>\n    </table>\n    {% endif %}\n\n    {% if doc.lab_test_prescription %}\n    <div style=\"margin-top: 20px;\">\n        <strong>Lab Tests Requested:</strong>\n        <ul>\n        {% for test in doc.lab_test_prescription %}\n            <li>{{ test.lab_test_name }}</li>\n        {% endfor %}\n        </ul>\n    </div>\n    {% endif %}\n\n    <div class=\"footer\">\n        <div></div>\n        <div class=\"signature\">\n            {{ doc.practitioner_name }}<br>\n            <small>{{ doc.medical_department or \"\" }}</small>\n        </div>\n    </div>\n</div>\n",
