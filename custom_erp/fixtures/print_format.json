  "format_data": null,
  "html": "\n<style>\n    .lab-report { font-family: Arial, sans-serif; }\n    .header { text-align: center; border-bottom: 2px solid #2563EB; padding-bottom: 10px; margin-bottom: 20px; }\n    .header h1 { color: #2563EB; margin: 0; }\n    .header h2 { color: #333; margin: 5px 0; font-size: 16px; }\n    .info-grid { display: flex; justify-content: space-between; margin-bottom: 20px; padding: 10px; background: #f8f9fa; border-radius: 5px; }\n    .results-table { width: 100%; border-collapse: collapse; margin: 15px 0; }\n    .results-table th { background: #2563EB; color: white; padding: 10px; text-align: left; }\n    .results-table td { padding: 10px; border-bottom: 1px solid #ddd; }\n    .results-table .abnormal { color: red; font-weight: bold; }\n    .results-table .normal { color: green; }\n    .footer { margin-top: 40px; display: flex; justify-content: space-between; }\n    .stamp { text-align: center; border-top: 1px solid #333; padding-top: 5px; min-width: 200px; }\n</style>\n\n<div class=\"lab-report\">\n    <div class=\"header\">\n        <h1>BDC Hospital - Laboratory</h1>\n        <h2>{{ doc.lab_test_name }}</h2>\n    </div>\n\n    <div class=\"info-grid\">\n        <div>\n            <strong>Patient:</strong> {{ doc.patient_name }}<br>\n            <strong>Age/Gender:</strong> {{ doc.patient_age or \"\" }} / {{ doc.patient_sex or \"\" }}<br>\n            <strong>Ref. Doctor:</strong> {{ doc.referring_practitioner or \"\" }}\n        </div>\n        <div style=\"text-align: right;\">\n            <strong>Lab No:</strong> {{ doc.name }}<br>\n            <strong>Date:</strong> {{ doc.result_date or doc.creation.strftime('%Y-%m-%d') }}<br>\n            <strong>Sample:</strong> {{ doc.sample or \"\" }}\n        </div>\n    </div>\n\n    {% if doc.normal_test_items %}\n    <table class=\"results-table\">\n        <thead>\n            <tr>\n                <th>Test</th>\n                <th>Result</th>\n                <th>Unit</th>\n                <th>Normal Range</th>\n                <th>Status</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for item in doc.normal_test_items %}\n            <tr>\n                <td>{{ item.lab_test_name }}</td>\n                <td><strong>{{ item.result_value or \"\" }}</strong></td>\n                <td>{{ item.lab_test_uom or \"\" }}</td>\n                <td>{{ item.min_value or \"\" }} - {{ item.max_value or \"\" }}</td>\n                <td>\n                    {% if item.result_value %}\n                        {% if item.result_value|float < item.min_value|float or item.result_value|float > item.max_value|float %}\n                            <span class=\"abnormal\">Abnormal</span>\n                        {% else %}\n                            <span class=\"normal\">Normal</span>\n                        {% endif %}\n                    {% endif %}\n                </td>\n            </tr>\n            {% endfor %}\n        </tbody>\n    </table>\n    {% endif %}\n\n    <div class=\"footer\">\n        <div class=\"stamp\">\n            Lab Technician\n        </div>\n        <div class=\"stamp\">\n            Lab Director\n        </div>\n    </div>\n</div>\n",
